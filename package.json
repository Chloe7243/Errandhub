{
  "name": "errandhub",
  "private": true,
  "workspaces": [
    "apps/*",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run start --workspace=apps/frontend\" \"npm run dev --workspace=apps/backend\" ",
    "backend": "npm run dev --workspace=apps/backend",
    "frontend": "npm run start --workspace=apps/frontend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@stripe/stripe-react-native": "^0.64.0",
    "expo-image-picker": "~17.0.10",
    "expo-notifications": "~0.32.16"
  }
}
