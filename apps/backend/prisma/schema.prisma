// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ErrandStatus {
  POSTED
  TENTATIVELY_ACCEPTED
  ACCEPTED
  IN_PROGRESS
  REVIEWING
  COMPLETED
  CANCELLED
  EXPIRED
  DISPUTED
}

enum PaymentStatus {
  PENDING
  HELD
  RELEASED
  REFUNDED
  DISPUTED
}

enum ErrandType {
  PICKUP_DELIVERY
  SHOPPING
}

// enum Complexity {
//   QUICK
//   STANDARD
//   COMPLEX
// }

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  CLOSED
}

enum OfferStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model User {
  id                String          @id @default(cuid())
  email             String          @unique
  firstName         String
  lastName          String
  phone             String
  passwordHash      String
  avatarUrl         String?
  isVerified        Boolean         @default(false)
  stripeAccountId   String?
  university        String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  role              String?
  resetToken        String?
  verificationToken String?
  resetTokenExpiry  DateTime?
  paymentMethods    PaymentMethod[] @relation("UserPaymentMethods")
  requestedErrands  Errand[]        @relation("RequesterErrands")
  helpingErrands    Errand[]        @relation("HelperErrands")
  messages          Message[]       @relation("UserMessages")
  raisedDisputes    Dispute[]       @relation("RaisedDisputes")
  errandOffers      ErrandOffer[]   @relation("HelperOffers")
  userSettings      UserSettings[]
}

model PaymentMethod {
  id                    String   @id @default(cuid())
  userId                String
  stripePaymentMethodId String
  last4                 String
  brand                 String
  expMonth              Int
  expYear               Int
  isDefault             Boolean  @default(false)
  createdAt             DateTime @default(now())

  user User @relation("UserPaymentMethods", fields: [userId], references: [id])
}

model UserSettings {
  id                 String   @id @default(cuid())
  userId             String   @unique
  isAvailable        Boolean  @default(false)
  notificationRadius Float    @default(2.0)
  errandUpdates      Boolean  @default(true)
  newMessages        Boolean  @default(true)
  promotions         Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Errand {
  id                    String       @id @default(cuid())
  requesterId           String
  helperId              String?
  title                 String
  description           String
  pickupLocation        String
  dropoffLocation       String
  pickupReference       String?
  suggestedPrice        Float?
  agreedPrice           Float?
  status                ErrandStatus @default(POSTED)
  reviewWindowExpiresAt DateTime?
  consecutiveCancels    Int          @default(0)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  proofImageUrl         String?
  proofNote             String?
  completedAt           DateTime?
  type                  ErrandType
  pickupLat             Float?
  pickupLng             Float?
  dropoffLat            Float?
  dropoffLng            Float?
  // complexity      Complexity

  payment   PaymentTransaction? @relation("ErrandPayment")
  messages  Message[]           @relation("ErrandMessages")
  helper    User?               @relation("HelperErrands", fields: [helperId], references: [id])
  requester User                @relation("RequesterErrands", fields: [requesterId], references: [id])
  dispute   Dispute?
  offers    ErrandOffer[]
}

model ErrandOffer {
  id        String      @id @default(cuid())
  errandId  String
  helperId  String
  amount    Float
  status    OfferStatus @default(PENDING)
  createdAt DateTime    @default(now())

  errand Errand @relation(fields: [errandId], references: [id])
  helper User   @relation("HelperOffers", fields: [helperId], references: [id])
}

model Message {
  id        String   @id @default(cuid())
  errandId  String
  senderId  String
  content   String?
  imageUrl  String?
  createdAt DateTime @default(now())

  errand Errand @relation("ErrandMessages", fields: [errandId], references: [id])
  sender User   @relation("UserMessages", fields: [senderId], references: [id])
}

model PaymentTransaction {
  id              String        @id @default(cuid())
  errandId        String        @unique
  amount          Float
  helperFee       Float
  stripeFee       Float
  stripePaymentId String?
  status          PaymentStatus @default(PENDING)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  errand Errand @relation("ErrandPayment", fields: [errandId], references: [id])
}

