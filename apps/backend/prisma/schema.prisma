// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ErrandStatus {
  POSTED
  ACCEPTED
  IN_PROGRESS
  REVIEWING
  COMPLETED
  CANCELLED
  EXPIRED
  DISPUTED
}

enum ErrandType {
  PICKUP_DELIVERY
  SHOPPING
  HANDS_ON_HELP
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  CLOSED
}

model User {
  id                String         @id @default(cuid())
  email             String         @unique
  firstName         String
  lastName          String
  phone             String
  passwordHash      String
  avatarUrl         String?
  isVerified        Boolean        @default(false)
  stripeAccountId   String?
  university        String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  role              String?
  expoPushToken     String?
  resetToken        String?
  verificationToken String?
  resetTokenExpiry  DateTime?
  requestedErrands  Errand[]       @relation("RequesterErrands")
  helpingErrands    Errand[]       @relation("HelperErrands")
  messages          Message[]      @relation("UserMessages")
  raisedDisputes    Dispute[]      @relation("RaisedDisputes")
  userSettings      UserSettings[]
}

model UserSettings {
  id                 String   @id @default(cuid())
  userId             String   @unique
  isAvailable        Boolean  @default(false)
  notificationRadius Float    @default(2.0)
  errandUpdates      Boolean  @default(true)
  newMessages        Boolean  @default(true)
  promotions         Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Errand {
  id                    String       @id @default(cuid())
  requesterId           String
  helperId              String?
  title                 String
  description           String
  firstLocation         String
  finalLocation         String?
  locationReference     String?
  suggestedPrice        Float?
  agreedPrice           Float?
  stripePaymentIntentId String?      @unique
  paymentMethodId       String?
  estimatedDuration     Float?
  startedAt             DateTime?
  finalCost             Float?
  status                ErrandStatus @default(POSTED)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  proofImageUrl         String?
  proofNote             String?
  completedAt           DateTime?
  type                  ErrandType
  firstLat              Float?
  firstLng              Float?
  finalLat              Float?
  finalLng              Float?

  messages  Message[] @relation("ErrandMessages")
  helper    User?     @relation("HelperErrands", fields: [helperId], references: [id])
  requester User      @relation("RequesterErrands", fields: [requesterId], references: [id])
  dispute   Dispute?
}

model Message {
  id        String   @id @default(cuid())
  errandId  String
  senderId  String
  content   String?
  imageUrl  String?
  createdAt DateTime @default(now())

  errand Errand @relation("ErrandMessages", fields: [errandId], references: [id])
  sender User   @relation("UserMessages", fields: [senderId], references: [id])
}

